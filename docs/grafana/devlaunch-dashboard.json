{
  "uid": "devlaunch-idp",
  "title": "DevLaunch IDP",
  "description": "Metrics for the DevLaunch Internal Developer Platform",
  "tags": ["devlaunch", "idp", "kubernetes"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Apps Created",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "devlaunch_apps_created_total",
          "legendFormat": "Created"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Apps",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "devlaunch_active_apps",
          "legendFormat": "Active"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Apps Deleted",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "devlaunch_apps_deleted_total",
          "legendFormat": "Deleted"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Deploy Failures",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "devlaunch_deploy_failures_total",
          "legendFormat": "Failures"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
      }
    },
    {
      "id": 5,
      "type": "graph",
      "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_received_total{job=\"devlaunch-idp\"}[1m])",
          "legendFormat": "{{method}} {{code}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "graph",
      "title": "HTTP Latency P95 (ms)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"devlaunch-idp\"}[5m])) * 1000",
          "legendFormat": "P95 latency"
        }
      ]
    },
    {
      "id": 7,
      "type": "graph",
      "title": "Reconcile Errors",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(devlaunch_reconcile_errors_total[5m])",
          "legendFormat": "Reconcile error rate"
        }
      ]
    },
    {
      "id": 8,
      "type": "graph",
      "title": ".NET Process Memory (MB)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "dotnet_total_memory_bytes / 1024 / 1024",
          "legendFormat": "Memory MB"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
